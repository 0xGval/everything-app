    "showTimestamp": {
      "type": "boolean",
      "label": "Show timestamp",
      "default": true
    },
    "displayMode": {
      "type": "select",
      "label": "Display mode",
      "default": "compact",
      "options": [
        { "label": "Compact", "value": "compact" },
        { "label": "Detailed", "value": "detailed" }
      ]
    }
  }
