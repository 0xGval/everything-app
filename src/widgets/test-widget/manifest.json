{
  "id": "test-widget",
  "name": "Test Widget",
  "description": "A test widget to verify the Widget SDK",
  "icon": "FlaskConical",
  "type": "native",
  "grid": {
    "minW": 2,
    "minH": 2,
    "defaultW": 4,
    "defaultH": 3
  },
  "permissions": [],
  "events": {
    "emits": [],
    "listens": []
  },
  "sharedState": {
    "reads": [],
    "writes": []
  },
  "hasExpandedView": false,
  "hasRustModule": false,
  "settings": {
    "refreshInterval": {
      "type": "number",
      "label": "Refresh interval (seconds)",
